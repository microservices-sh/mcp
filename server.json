{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "sh.microservices/mcp",
  "title": "microservices.sh",
  "description": "MCP server for AI agents to plan, verify, and deploy Cloudflare-native apps.",
  "status": "active",
  "repository": {
    "url": "https://github.com/microservices-sh/mcp",
    "source": "github"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@microservices-sh/mcp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.microservices.sh/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer ${MICROSERVICES_API_KEY}",
          "isSecret": true
        }
      ]
    }
  ]
}
